# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# YouTube OAuth2 Configuration
YOUTUBE_CREDENTIALS_FILE=credentials/client_secret.json

# Application Settings
DEBUG=False
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# FFmpeg Configuration (optional - leave empty to use system PATH)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Optional: Custom base URL for OpenAI (for proxies)
# OPENAI_API_BASE=https://api.openai.com/v1
